# 飞书开放平台应用凭证
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 默认账本：用于本地 --text 测试；飞书用户会通过“绑定账本 <链接>”各自绑定独立账本
BITABLE_APP_TOKEN=bascnxxxxxxxxxxxxxxxx
TABLE_ID=tblxxxxxxxxxxxxxx
BITABLE_VIEW_URL=https://xxxx.feishu.cn/base/xxxx?table=tblxxxxxxxxxxxxxx&view=vewxxxxxxxxxxxxxx

# 模型选择：qwen / openai / fallback
LLM_PROVIDER=fallback
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxx
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-plus
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 服务配置
# Railway 会自动注入 PORT；本地 Docker/云服务器可用 SERVER_PORT。
SERVER_HOST=0.0.0.0
SERVER_PORT=18000
REQUEST_TIMEOUT=30
LLM_TIMEOUT=60
LLM_MAX_RETRIES=2

# SQLite 持久化路径
# Railway 推荐创建 Volume 并挂载到 /app/data，或保留为空让程序使用 RAILWAY_VOLUME_MOUNT_PATH。
ACCOUNTING_DB_PATH=
