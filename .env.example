# 飞书开放平台应用凭证
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书多维表格 Bitable
# 普通 Bitable 链接形如 https://xxx.feishu.cn/base/<BITABLE_APP_TOKEN>?table=<TABLE_ID>
# wiki 链接请用 scripts/resolve_wiki_bitable_token.py 转换
BITABLE_APP_TOKEN=bascnxxxxxxxxxxxxxxxx
TABLE_ID=tblxxxxxxxxxxxxxx

# 模型选择：qwen / openai / fallback
# fallback 表示优先 Qwen，失败后自动切 OpenAI
LLM_PROVIDER=fallback

# Qwen / 通义千问，OpenAI Chat Completions 兼容接口
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxx
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-plus

# OpenAI GPT，作为可选备用模型
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 兼容旧版单模型配置，可不填
# GPT_API_KEY=sk-xxxxxxxxxxxxxxxx
# GPT_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# GPT_MODEL=qwen3.7-plus

# 本地服务配置
SERVER_HOST=0.0.0.0
SERVER_PORT=18000
REQUEST_TIMEOUT=30
LLM_TIMEOUT=60
LLM_MAX_RETRIES=2
